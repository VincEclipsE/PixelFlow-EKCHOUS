# User-saved tool library (runtime artifact, not source).
# Bundled sample-*.pftool files ship as starters and ARE tracked.
tools/*.pftool
tools/*.png
!tools/.gitkeep
!tools/sample-*.pftool

# Project save files (user content, not source)
*.pflow
!starters/*.pflow

# Local-only Claude state (kept per-machine)
.claude/settings.local.json

# Temporary native logs
JOGL-*.log
hs_err_*.log
